# Template for local development. Copy to .env and fill in real values:
#   cp .env.example .env
# .env is git-ignored; this template is committed. Keep the two in sync when
# adding a new setting, but never put real secrets here.

# Your Financial Modeling Prep API key.
FinancialDataApiKey=your-fmp-api-key-here

# SQL connection string for the StockAggregator database, using Microsoft Entra.
# No Authentication keyword needed: the app fills it in automatically — interactive
# browser sign-in locally, managed identity in Azure. To force a mode, uncomment
# SqlAuthentication below (e.g. "Active Directory Interactive").
#
# Replace <your-sql-server> with your Azure SQL server name.
SqlConnectionString=Server=tcp:<your-sql-server>.database.windows.net,1433;Initial Catalog=StockAggregator;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;
# SqlAuthentication=Active Directory Interactive

# Comma-separated tickers to capture.
StockSymbols=NVDA,AAPL,MSFT

# Optional: override the FMP endpoint. Defaults to the batch quote endpoint.
FmpQuoteBaseUrl=https://financialmodelingprep.com/api/v3/quote

# Makes the timer triggers fire on Central time and follow daylight saving.
WEBSITE_TIME_ZONE=Central Standard Time
