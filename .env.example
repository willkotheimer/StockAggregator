# Template for local development. Copy to .env and fill in real values:
#   cp .env.example .env
# .env is git-ignored; this template is committed. Keep the two in sync when
# adding a new setting, but never put real secrets here.

# Your Financial Modeling Prep API key.
FinancialDataApiKey=your-fmp-api-key-here

# SQL Server connection string for the StockAggregator database.
SqlConnectionString=Server=localhost;Database=StockAggregator;Trusted_Connection=True;TrustServerCertificate=True;

# Comma-separated tickers to capture.
StockSymbols=NVDA,AAPL,MSFT

# Optional: override the FMP endpoint. Defaults to the batch quote endpoint.
FmpQuoteBaseUrl=https://financialmodelingprep.com/api/v3/quote

# Makes the timer triggers fire on Central time and follow daylight saving.
WEBSITE_TIME_ZONE=Central Standard Time
